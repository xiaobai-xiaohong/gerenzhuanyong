# ============================================
# MnemOS v6.0 配置文件
# ============================================

# 嵌入模型（必填）
# 申请地址：https://siliconflow.cn/
MODEL_PROVIDER=siliconflow
SILICONFLOW_API_KEY=your-siliconflow-api-key-here
# SILICONFLOW_MODEL=BAAI/bge-m3

# LLM 配置（用于自动提取事实）
# 使用 SiliconFlow 的 DeepSeek 模型
LLM_API_KEY=your-siliconflow-api-key-here
LLM_BASE_URL=https://api.siliconflow.cn
LLM_MODEL=deepseek-ai/deepseek-v4-flash
LLM_MAX_TOKENS=4096

# 自动提取配置
AUTO_EXTRACT_ENABLED=true
AUTO_EXTRACT_INTERVAL=3600
AUTO_EXTRACT_MIN_MESSAGES=5

# 安全配置（必填）
# 用于 API 认证，在请求 Header 中携带：x-api-key: <此值>
MNEMOSYNE_API_KEY=change-me-to-random-string

# 存储策略（默认 auto，自动探测硬件）
STORAGE_STRATEGY=auto

# 数据库（已在 docker-compose.yml 配好，无需修改）
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=mnemosyne
# POSTGRES_USER=mnemosyne
# POSTGRES_PASSWORD=your-password-here

# Redis（已在 docker-compose.yml 配好，无需修改）
# REDIS_ADDR=redis:6379
