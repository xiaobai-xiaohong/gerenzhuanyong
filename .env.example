# MiniMax API Key（必须，https://platform.minimax.chat/ 申请）
MODEL_API_KEY=your-model-api-key-here

# Mnemosyne 服务 API Key（自定义，随便写一个）
MNEMOSYNE_API_KEY=mnemosyne-api-key-change-me

# 存储策略（默认 auto，自动探测硬件）
STORAGE_STRATEGY=auto

# 数据库（已在 docker-compose.yml 配好，无需修改）
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=mnemosyne
# POSTGRES_USER=mnemosyne
# POSTGRES_PASSWORD=your-password-here

# Redis（已在 docker-compose.yml 配好，无需修改）
# REDIS_ADDR=redis:6379

# 代理（国内环境需要，海外可删除）
# HTTP_PROXY=http://host.docker.internal:7897
# HTTPS_PROXY=http://host.docker.internal:7897
