@@ -26,6 +26,101 @@ from agent.thread_scoped_output import thread_scoped_silence

 logger = logging.getLogger(__name__)

+# ---------------------------------------------------------------------------
+# MnemOS v6.0 MCP bridge helpers
+# ---------------------------------------------------------------------------
+# MnemOS is wired as an external MCP server via mcp_servers.mnemos in config.
+# The model calls MCP tools (mnemos_health, mnemos_search, mnemos_memories,
+# mnemos_feedback) directly — no in-process call needed.
+# These helpers construct the "how to call MnemOS" guidance injected into
+# the review prompt when the MCP server is configured.
+# ---------------------------------------------------------------------------
+
+_MNEMOS_SYSTEM_GUIDANCE = (
+    "\n\nMnemOS Memory Tools (MCP):\n"
+    "Use these tools to store and retrieve long-term memories:\n"
+    "  mnemos_search(query=<keywords>, depth='auto', top_k=5)\n"
+    "  mnemos_feedback(memory_id=<id>, helpful=true)\n"
+    "  mnemos_feedback(memory_id=<id>, helpful=false)\n"
+    "  mnemos_health()\n"
+    "Memory types: W=workflow iron rule, K=tool knowledge,\n"
+    "I=identity/person, D=dialogue, E=pitfall, R=reflection, S=research.\n"
+)
+
+
+def _mnemos_store(
+    content: str,
+    *,
+    memory_type: str = "general",
+    title: str = "",
+    metadata: Optional[Dict[str, Any]] = None,
+) -> Dict[str, Any]:
+    """Archive a new memory into MnemOS via its REST API.
+
+    Called by the review agent when it decides to persist a learning.
+    Falls back to a no-op dict on network errors so review never breaks.
+    """
+    try:
+        import urllib.request
+        import urllib.error
+        base = os.environ.get("MNEMOS_BASE_URL", "http://localhost:8010")
+        body = {
+            "content": content,
+            "content_type": "text",
+            "title": title or content[:80],
+            "memory_type": memory_type,
+        }
+        data = json.dumps(body).encode()
+        req = urllib.request.Request(
+            f"{base}/api/v5/memory/archive",
+            data=data,
+            headers={"Content-Type": "application/json"},
+        )
+        with urllib.request.urlopen(req, timeout=15) as r:
+            result = json.loads(r.read().decode())
+        if result.get("code") == 0:
+            return {"success": True, "data": result.get("data", {})}
+        return {"success": False, "error": result.get("message", "archive failed")}
+    except urllib.error.HTTPError as e:
+        try:
+            body = json.loads(e.read().decode())
+            return {"success": False, "error": body.get("detail", f"HTTP {e.code}")}
+        except Exception:
+            return {"success": False, "error": f"HTTP {e.code}"}
+    except Exception as e:
+        logger.debug("MnemOS store failed: %s", e)
+        return {"success": False, "error": str(e)}
+
+
+def _mnemos_recall(
+    query: str,
+    *,
+    depth: str = "auto",
+    top_k: int = 5,
+) -> Dict[str, Any]:
+    """Search MnemOS long-term memory for relevant entries.
+
+    Returns {"success": True, "results": [...]} or {"success": False}.
+    """
+    try:
+        import urllib.request
+        import urllib.error
+        base = os.environ.get("MNEMOS_BASE_URL", "http://localhost:8010")
+        body = {"query": query, "depth": depth, "top_k": top_k}
+        data = json.dumps(body).encode()
+        req = urllib.request.Request(
+            f"{base}/api/v5/memory/search",
+            data=data,
+            headers={"Content-Type": "application/json"},
+        )
+        with urllib.request.urlopen(req, timeout=15) as r:
+            result = json.loads(r.read().decode())
+        if result.get("code") == 0:
+            return {"success": True, "data": result.get("data", {})}
+        return {"success": False, "error": result.get("message", "search failed")}
+    except urllib.error.HTTPError as e:
+        try:
+            body = json.loads(e.read().decode())
+            return {"success": False, "error": body.get("detail", f"HTTP {e.code}")}
+        except Exception:
+            return {"success": False, "error": f"HTTP {e.code}"}
+    except Exception as e:
+        logger.debug("MnemOS recall failed: %s", e)
+        return {"success": False, "error": str(e)}
+
 
